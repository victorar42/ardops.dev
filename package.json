{
  "name": "ardops-dev",
  "version": "1.0.0",
  "private": true,
  "description": "Sitio profesional ardops.dev — DevOps Engineer (sitio estático).",
  "scripts": {
    "html-validate": "html-validate index.html blog/index.html blog/pipeline-seguridad-spec-driven.html talks/index.html speaking/index.html uses/index.html now/index.html privacy/index.html 404.html",
    "a11y": "node tests/a11y.js",
    "pa11y": "pa11y-ci --config tests/pa11y.config.js",
    "lhci": "lhci autorun --config=tests/lighthouserc.json",
    "serve": "npx --yes serve -l 8080 .",
    "build:layout": "node scripts/build-layout.js",
    "build:interviews": "node scripts/build-interviews.js --strict --out interviews/",
    "build:blog": "node scripts/build-blog.js",
    "build:syntax-css": "node scripts/build-syntax-css.js",
    "build:og": "node scripts/build-og.js",
    "build": "npm run build:layout && npm run build:syntax-css && npm run build:og && npm run build:blog && npm run build:interviews",
    "check:og": "node scripts/build-og.js --check",
    "check:og-images": "bash tests/og-images.sh",
    "check:og-drift": "bash tests/og-drift.sh",
    "check:layout": "node scripts/build-layout.js --check",
    "check:syntax-css": "node scripts/build-syntax-css.js --check",
    "check:syntax-css-size": "bash tests/syntax-css-size.sh",
    "check:syntax-css-conditional": "bash tests/syntax-css-conditional.sh",
    "check:no-inline-styles-blog": "bash tests/no-inline-styles-blog.sh",
    "check:build-blog": "bash tests/build-blog-check.sh",
    "check:nav": "bash tests/nav-consistency.sh",
    "check:csp": "bash tests/csp-no-unsafe-inline.sh",
    "check:links": "bash tests/external-links.sh",
    "check:sitemap": "bash tests/sitemap-drift.sh",
    "check:feeds": "bash tests/feed-validate.sh",
    "check:jsonld": "bash tests/jsonld-validate.sh",
    "check:seo": "bash tests/seo-meta.sh",
    "check:headshot": "bash tests/headshot-size.sh",
    "check:now-freshness": "bash tests/now-freshness.sh",
    "check:byte-budgets": "bash tests/byte-budgets.sh",
    "check:img-attrs": "bash tests/img-attrs.sh",
    "check:fonts": "bash tests/no-third-party-fonts.sh",
    "check:no-trackers": "bash tests/no-trackers.sh",
    "check:no-cookies": "bash tests/no-cookies.sh",
    "check:distribution": "npm run check:feeds && npm run check:jsonld && npm run check:seo && npm run check:headshot && npm run check:now-freshness && npm run check:byte-budgets && npm run check:img-attrs && npm run check:fonts && npm run check:no-trackers && npm run check:no-cookies && npm run check:og-images && npm run check:og-drift",
    "check:security": "npm run check:csp && npm run check:links && npm run check:sitemap"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "axe-core": "^4.11.3",
    "dompurify": "^3.1.6",
    "gray-matter": "^4.0.3",
    "html-validate": "^9.0.0",
    "jsdom": "^24.1.1",
    "marked": "^12.0.2",
    "pa11y-ci": "^3.1.0",
    "puppeteer": "^22.15.0",
    "sharp": "^0.33.5",
    "shiki": "^4.0.2"
  }
}
